# 不動産情報ライブラリAPI（国土交通省）
# https://www.reinfolib.mlit.go.jp/help/apiManual/
REINFOLIB_API_KEY=your_api_key_here

# LLM推論サーバー設定
LLM_ENABLED=true
LLM_API_URL=http://localhost:8001/v1
LLM_MODEL_NAME=
LLM_TIMEOUT=120
LLM_MAX_TOKENS_YOUKAI=2048
LLM_MAX_TOKENS_DEFAULT=512
LLM_TEMPERATURE=0.3

# TTS設定（VOICEVOX）
TTS_ENABLED=true
TTS_API_URL=http://localhost:50021
TTS_TIMEOUT=30
TTS_CACHE_MAX_SIZE=100
